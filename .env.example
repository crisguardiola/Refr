# Drizzle
# Replace with your DB credentials!
DATABASE_URL="postgres://user:password@host:port/db-name"

ORIGIN=""

# Better Auth
# For production use 32 characters and generated with high entropy
# https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET=""

# Optional: Google OAuth (for "Continue with Google")
# Get credentials from https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# Cloudinary (use one option)
# Option 1: Single URL from https://console.cloudinary.com/settings/api-keys
CLOUDINARY_URL="cloudinary://api_key:api_secret@cloud_name"
# Option 2: Separate vars
# CLOUDINARY_CLOUD_NAME=""
# CLOUDINARY_API_KEY=""
# CLOUDINARY_API_SECRET=""
